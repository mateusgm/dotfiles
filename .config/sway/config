
# Foundations
    # variables
    set $mod Mod4
    set $term foot
    set $menu \
         XDG_DATA_DIRS=/home/$USER/.local/share/flatpak/exports/share:/var/lib/flatpak/exports/share:$XDG_DATA_DIRS \
         rofi -terminal '$term' -show combi -combi-modes drun#run -modes combi

    # xway
    xwayland enable
    exec systemctl --user import-environment DISPLAY

    # close, reload
    bindsym $mod+Shift+w kill
    bindsym $mod+Shift+r reload
    bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes, exit sway' 'swaymsg exit'

# Input configuration
    # swaymsg -t get_inputs

    input type:touchpad {
        dwt enabled
        tap enabled
        natural_scroll enabled
        middle_emulation enabled
    }
    input * {
        xkb_layout "us"
        xkb_variant "intl"
    }

# Apps:
    bindsym $mod+Return exec $term
    bindsym $mod+Space exec $menu

    # htop
    bindsym $mod+escape exec $term -a 'flying-foot' htop
    for_window [app_id="flying-foot"] floating enable, resize set width 1000px height 600px

    # wifi
    exec --no-startup-id 'nm-applet --indicator'

    # notifications
    exec mako

    # print screen
    bindsym $mod+Print exec grim -t png -g "$(slurp)" ~/Downloads/$(date +%Y-%m-%d_%H-%M-%S).png
    bindsym Shift+Print exec grim -g "$(slurp)" - | wl-copy

    # calc
    bindsym $mod+c exec gnome-calculator 
    for_window [app_id="org.gnome.Calculator"] floating enable

    # browser
    bindsym $mod+b exec brave-browser --force-device-scale-factor=1.1 --enable-features=UseOzonePlatform --enable-gpu --ozone-platform=wayland --enable-features=WebRTCPipeWireCapturer
    for_window [app_id = "brave-(?!browser).*"] floating enable

    # file
    bindsym $mod+v exec thunar
    for_window [app_id="thunar"] floating enable, resize set height 800px



# Moving around:
    floating_modifier $mod normal

    # Focus
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right
    bindsym $mod+p focus parent

    # Move window
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

# Workspaces:
    # Switch to workspace
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+Alt+Right workspace next
    bindsym $mod+Alt+Left workspace prev

    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Alt+Shift+Left move container to workspace next, workspace next
    bindsym $mod+Alt+Shift+Right move container to workspace prev, workspace next

    # scratchpad:
    bindsym $mod+minus move scratchpad
    bindsym $mod+equal scratchpad show

# Layout stuff:
    # split
    bindsym $mod+backslash splith
    bindsym $mod+bar splitv

    # style
    bindsym $mod+a layout tabbed
    bindsym $mod+s layout stacking
    bindsym $mod+d layout toggle split
    bindsym $mod+f fullscreen
    bindsym $mod+z floating toggle
    bindsym $mod+x focus mode_toggle

    # Resizing
    bindsym Control+$mod+Left resize shrink width 100px
    bindsym Control+$mod+Right resize grow width 100px
    bindsym Control+$mod+Down resize grow height 50px
    bindsym Control+$mod+Up resize shrink height 50px


# Appearance
    # Background
    # Requires: desktop-backgrounds-compat, swaybg, jxl-pixbuf-loader
    output * bg /usr/share/backgrounds/default.jxl fill

    # desktop
    output * scale 1
    default_border none

    # floating windows
    for_window [app_id="foot"] border pixel
    for_window [window_role = "pop-up"] floating enable
    for_window [window_role = "bubble"] floating enable
    for_window [window_role = "dialog"] floating enable
    for_window [window_type = "dialog"] floating enable
    for_window [window_role = "task_dialog"] floating enable
    for_window [window_type = "menu"] floating enable
    for_window [app_id = "floating"] floating enable
    for_window [app_id = "floating_update"] floating enable, resize set width 1000px height 600px
    for_window [class = "(?i)pinentry"] floating enable
    for_window [title = "Administrator privileges required"] floating enable


# Idle configuration
    # exec swayidle -w \
    #          timeout 300 'swaylock -f -c 000000' \
    #          timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
    #          before-sleep 'swaylock -f -c 000000'
    #

# Includes
    exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway   

    include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'
