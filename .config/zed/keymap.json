// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      "cmd-escape": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-cmd-shift-t": "file_finder::Toggle",
      "cmd-t": "terminal_panel::Toggle",
    },
  },
  {
    "bindings": {
      "alt-cmd-n": "terminal::RenameTerminal"
    }
  },
  {
    "context": "(RecentProjects || RecentProjects > Picker > Editor)",
    "bindings": {
      "cmd-shift-o": "workspace::AddFolderToProject"
    }
  }
]
