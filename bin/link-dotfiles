#!/bin/bash

DOTFILES="$(pwd)"
HOME_DIR="$HOME"


# platform
PLATFORM="linux"
if [ $(uname) = "Darwin" ]; then
  PLATFORM="mac"
fi
echo "Platform: $PLATFORM"

# skipping logic
should_skip() {
  [[ $1 == *.mac ]] && return 0
  [[ $1 == *.linux ]] && return 0
  grep -xq "$1" $DOTFILES/.dotignore && return 0
  return 1
}

# symlink top-level files/dirs to home
for item in "$DOTFILES"/.*; do
  name="$(basename "$item")"
  should_skip "$name" && continue
  ln -sfn "$item" "$HOME_DIR/$name"
  echo "Linked $name -> $item"
done


# handle platform-specific configs (.mac / .linux)
find "$DOTFILES" -type f -name "*.$PLATFORM" | while read -r file; do
  name="$(basename ${file%.$PLATFORM})"
  ln -sfn "$file" "$HOME_DIR/$name"
  echo "Platform link $name -> $file"
done
