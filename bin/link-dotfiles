#!/bin/bash

DOTFILES="$(pwd)"
HOME_DIR="$HOME"


# platform
PLATFORM="linux"
if [ $(uname) = "Darwin" ]; then
  PLATFORM="mac"
fi
echo "Platform: $PLATFORM"

# skipping logic
should_skip() {
  [[ $1 == "." ]] && return 0
  [[ $1 == ".." ]] && return 0
  [[ $1 == ".config" ]] && return 0
  [[ $1 == *.mac ]] && return 0
  [[ $1 == *.linux ]] && return 0
  grep -xq "$1" $DOTFILES/.dotignore && return 0
  return 1
}

link_files() {
  # symlink top-level files/dirs to home
  for item in $DOTFILES/$1*; do
    name="$(basename "$item")"
    name="${name#*.}"
    should_skip "$name" && continue
    ln -sfn "$item" "$HOME_DIR/$1$name"
    echo "Linked $1$name -> $item"
  done
}

link_files ".config/"
link_files "."

# handle platform-specific configs (.mac / .linux)
find "$DOTFILES" -type f -name "*.$PLATFORM" | while read -r file; do
  name="$(basename ${file%.$PLATFORM})"
  dir=`dirname "${file#"$DOTFILES"/}"` 
  ln -sfn "$file" "$HOME_DIR/$dir/$name"
  echo "Platform link $dir/$name -> $file"
done
