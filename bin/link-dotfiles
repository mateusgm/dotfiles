#!/bin/bash

EXCLUDE=(
  ".git"
  ".gitignore"
  "README.md"
  "install.sh"
  ".DS_Store"
)
DOTFILES="$(pwd)"
HOME_DIR="$HOME"


# platform
PLATFORM="linux"
if [ $(uname) = "Darwin" ]; then
  PLATFORM="mac"
fi
echo "Platform: $PLATFORM"

# skipping logic
should_skip() {
  for e in "${EXCLUDE[@]}"; do
    [ "$1" = "$e" ] && return 0
  done
  return 1
}

# symlink top-level files/dirs to home
for item in "$DOTFILES"/*; do
  name="$(basename "$item")"
  should_skip "$name" && continue
  target="$HOME_DIR/.$name"
  ln -sfn "$item" "$target"
  echo "Linked $target -> $item"
done


# handle platform-specific configs (.mac / .linux)
find "$DOTFILES" -type f -name "*.$PLATFORM" | while read -r file; do
  base="${file%.$PLATFORM}"
  ln -sfn "$file" "$base"
  echo "Platform link $base -> $file"
done
