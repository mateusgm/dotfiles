[user]
  name = mateusgm
  email = 470509+mateusgm@users.noreply.github.com
[alias]
  hist = log --graph --color=always --pretty='[%C(cyan)%h%Creset]%C(bold cyan)%d%Creset %s' --all
  co = checkout
  br = for-each-ref --sort=-committerdate refs/heads/
  ci = commit
  cia = commit -a
  co = checkout
  st = status -s
  me = log --author=mateus.melo
  lg = !git log | head -n 20
	lastwc = !git last | wc
	change-commits = "!f() { VAR=$1; OLD=$2; NEW=$3; shift 3; git filter-branch --env-filter \"if [[ \\\"$`echo $VAR`\\\" = '$OLD' ]]; then export $VAR='$NEW'; fi\" $@; }; f"
  prune-branches = "!f() { git branch --merged main | grep -v '^\\* main' | grep -v '^main' | xargs -n 1 git branch -d }"
[color]
  ui = always
[push]
  default = current
[core]
  editor = vim
  symlinks = true
  autocrlf = input
  excludesFile = ~/.gitignore_global
[apply]
  whitespace = nowarn
[log]
  date = short
  color = always
[format]
  pretty = format:%C(auto,yellow)%h %C(auto)%>(12,trunc)%ad (%C(Green)%cr%C(reset))%x09 %C(auto,Cyan)%<(12,trunc)%aN%x09 : %C(auto,reset)%s %C(auto,red)% gD% D
[submodule]
  recurse = true
